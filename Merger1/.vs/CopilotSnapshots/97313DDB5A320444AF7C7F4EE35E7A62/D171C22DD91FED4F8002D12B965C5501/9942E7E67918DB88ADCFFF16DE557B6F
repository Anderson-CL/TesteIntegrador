        }


        //Botão que adiciona os produtos na tabela
        private void AdicionarAoCarrinho(Produto produtoSelecionado)
        {

            var itemExistente = carrinho.FirstOrDefault(c => c.Produto.Nome == produtoSelecionado.Nome);
            if (itemExistente != null)
            {
                itemExistente.Quantidade++;
            }
            else
            {
                carrinho.Add(new CarrinhoCompra { Produto = produtoSelecionado, Quantidade = 1 });
            }
            AtualizarCarrinhoUI();

            decimal totalGeral = carrinho.Sum(c => c.Total);



            lblTotal_Text.Text = $"Total: R$ {totalGeral}";
        }


        public void AtualizarCarrinhoUI()
        {
            DataGrid_Produtos.DataSource = null;
            DataGrid_Produtos.DataSource = carrinho;
        }

