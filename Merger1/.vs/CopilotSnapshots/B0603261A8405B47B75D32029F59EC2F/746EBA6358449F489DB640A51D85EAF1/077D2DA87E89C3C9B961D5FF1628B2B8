using CaixaIntegrador.Classes;

namespace CaixaIntegrador
{
    public partial class UCAberto : UserControl
    {
        // Armazena a lista de pedidos em aberto
        private List<Pedido> pedidosAbertos = new List<Pedido>();
        // Pedido selecionado atualmente
        private Pedido pedidoSelecionado;

        // Evento para ir para finalizados
        public event Action IrParaFinalizado;
        // Evento para voltar ao caixa
        public event Action VoltarParaCaixa;
        // Evento para carregar pedido no caixa
        public event Action<Pedido> CarregarPedidoNoCaixa;

        public UCAberto()
        {
            InitializeComponent();
            btnIrFinalizado.Click += btnIrFinalizado_Click;
            btnVoltarCaixa.Click += btnVoltarCaixa_Click;
            dataGridView1.SelectionChanged += DataGridView1_SelectionChanged;
        }

        // Carrega os pedidos com status Aberto da lista geral
        public void CarregarAberto(List<Pedido> pedidos)
        {
            pedidosAbertos = pedidos.Where(p => p.Status == PedidoStatus.Aberto).ToList();
            AtualizarUI();
        }

        // Atualiza a exibição dos pedidos na DataGrid
        private void AtualizarUI()
        {
            dataGridView1.DataSource = null;
            dataGridView1.DataSource = pedidosAbertos.Select(p => new
            {
                p.Id,
                DataCriacao = p.DataCriacao.ToString("dd/MM/yyyy HH:mm"),
                Total = $"R$ {p.Total:F2}",
                Itens = p.Itens.Count
            }).ToList();
        }

        // Detecta qual pedido foi selecionado
        private void DataGridView1_SelectionChanged(object sender, EventArgs e)
        {
            if (dataGridView1.SelectedRows.Count > 0)
            {
                int pedidoId = Convert.ToInt32(dataGridView1.SelectedRows[0].Cells[0].Value);
                pedidoSelecionado = pedidosAbertos.FirstOrDefault(p => p.Id == pedidoId);

                if (pedidoSelecionado != null)
                {
                    ExibirDetalhesPedido();
                }
            }
        }

        // Exibe os detalhes e itens do pedido selecionado
        private void ExibirDetalhesPedido()
        {
            if (pedidoSelecionado == null) return;

            string detalhes = $"Pedido #{pedidoSelecionado.Id}\n";
            detalhes += $"Data: {pedidoSelecionado.DataCriacao:dd/MM/yyyy HH:mm}\n";
            detalhes += $"Total: R$ {pedidoSelecionado.Total:F2}\n";
            detalhes += $"\nItens:\n";

            foreach (var item in pedidoSelecionado.Itens)
            {
                detalhes += $"- {item.Produto} x{item.Qtd} = R$ {item.Total:F2}\n";
            }

            MessageBox.Show(detalhes, "Detalhes do Pedido");
        }

        // Carrega o pedido selecionado de volta no caixa para edição
        private void btnVoltarPedidoCaixa_Click(object sender, EventArgs e)
        {
            if (pedidoSelecionado == null)
            {
                MessageBox.Show("Selecione um pedido primeiro!", "Aviso");
                return;
            }

            CarregarPedidoNoCaixa?.Invoke(pedidoSelecionado);
        }

        // Alterna para a tela de pedidos finalizados
        private void btnIrFinalizado_Click(object sender, EventArgs e)
        {
            IrParaFinalizado?.Invoke();
        }

        // Volta para a tela do caixa
        private void btnVoltarCaixa_Click(object sender, EventArgs e)
        {
            VoltarParaCaixa?.Invoke();
        }
    }
}
